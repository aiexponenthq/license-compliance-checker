pipeline {
  agent any
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }
    stage('Install LCC') {
      steps {
        sh 'python -m pip install --upgrade pip'
        sh 'pip install .'
      }
    }
    stage('Run Compliance Scan') {
      steps {
        sh 'lcc scan . --format json --output lcc-report.json --threshold 0.5'
      }
    }
  }
  post {
    always {
      archiveArtifacts artifacts: 'lcc-report.json', fingerprint: true
    }
  }
}
